---
layout: default
title: "Docs"
description: "Documentation for RoseVision CAD Studio and related Rose City Robotics tooling."
permalink: /docs/
---

<%= render SimpleLayout.new(eyebrow: "Reference", title: "Documentation", intro: "Guides and references for RoseVision CAD Studio and related tooling.") do %>
  <% docs = collections.docs.resources %>
  <% if docs.any? %>
    <% by_category = docs.group_by { |d| d.data.category || "General" } %>
    <div class="space-y-12">
      <% by_category.each do |category, category_docs| %>
        <section>
          <h2 class="text-lg font-semibold text-gray-900"><%= category %></h2>
          <ul class="mt-4 space-y-2 border-t border-gray-100 pt-4">
            <% category_docs.each do |doc| %>
              <li>
                <a href="<%= doc.relative_url %>" class="group flex items-baseline justify-between rounded-lg px-3 py-2 hover:bg-gray-50">
                  <span class="text-sm font-medium text-gray-900 group-hover:text-primary-600"><%= doc.data.title %></span>
                  <span class="text-xs text-gray-400" aria-hidden="true">→</span>
                </a>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-600">No docs yet. Check back soon.</p>
  <% end %>
<% end %>
