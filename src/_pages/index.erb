<!-- Latest articles -->
<% latest_articles = collections.articles.resources.first(3) %>
<% if latest_articles.any? %>
  <section class="mt-24 mb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">From the lab</h2>
        <p class="mt-2 text-lg leading-8 text-gray-600">Research notes, deployment lessons, and what we're working on next.</p>
      </div>
      <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <% latest_articles.each do |article| %>
          <article class="flex flex-col">
            <% if article.data.image %>
              <img src="<%= relative_url(article.data.image) %>" alt="" class="aspect-[16/9] w-full rounded-2xl bg-gray-100 object-cover" />
            <% end %>
            <div class="mt-6">
              <% if article.data.published_at %>
                <time class="text-xs text-gray-500" datetime="<%= article.data.published_at %>">
                  <%= Date.parse(article.data.published_at.to_s).strftime("%B %-d, %Y") %>
                </time>
              <% end %>
              <h3 class="mt-2 text-lg font-semibold text-gray-900">
                <a href="<%= article.relative_url %>" class="hover:text-primary-600"><%= article.data.title %></a>
              </h3>
              <% if article.data.meta_description %>
                <p class="mt-2 text-sm text-gray-600"><%= article.data.meta_description %></p>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
      <div class="mt-10">
        <a href="/articles/" class="btn btn-link px-0">All articles <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
<% end %>
