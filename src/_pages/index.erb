      <img src="<%= relative_url('/images/google_grey.png') %>" alt="Google" class="max-h-12 w-auto object-contain" height="48" />
      <img src="<%= relative_url('/images/abb-logo-grey.png') %>" alt="ABB Robotics" class="max-h-12 w-auto object-contain" height="48" />
      <img src="<%= relative_url('/images/FANUC-Logo-grey.png') %>" alt="FANUC" class="max-h-12 w-auto object-contain" height="48" />
    </div>
