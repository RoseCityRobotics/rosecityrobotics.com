      <p class="eyebrow text-center mb-8 text-gray-500">Backed by Oregon's manufacturing ecosystem</p>
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 opacity-60">
        <img src="<%= relative_url('/images/omep-grey.png') %>" alt="OMEP Oregon Manufacturing Extension Partnership" class="max-h-10 w-auto object-contain" height="40" />
        <img src="<%= relative_url('/images/omic-grey.svg') %>" alt="OMIC Oregon Manufacturing Innovation Center" class="max-h-10 w-auto object-contain" height="40" />
      </div>
    </div>
  </div>
</div>

