---
layout: default
---
<%
  # Stored as UTC (…Z); display in the site timezone (America/Los_Angeles, set
  # via bridgetown.config.yml `timezone`, which sets ENV["TZ"] at build time).
  start_dt = resource.data.start_datetime && Time.parse(resource.data.start_datetime.to_s).getlocal
  end_dt = resource.data.end_datetime && Time.parse(resource.data.end_datetime.to_s).getlocal
%>
<%= render Container.new(outer_class: "mt-16 sm:mt-24") do %>
  <article class="max-w-3xl">
    <nav class="flex text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-500">
        <li><a href="/" class="hover:text-primary-600">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/events/" class="hover:text-primary-600">Events</a></li>
      </ol>
    </nav>

    <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      <%= resource.data.title %>
    </h1>

    <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 text-sm">
      <% if start_dt %>
        <div>
          <dt class="font-semibold text-gray-700">When</dt>
          <dd class="text-gray-600">
            <time datetime="<%= start_dt.iso8601 %>">
              <%= start_dt.strftime("%A, %B %-d, %Y · %-l:%M %p %Z") %>
            </time>
            <% if end_dt %>
              <span> – <%= end_dt.strftime("%-l:%M %p %Z") %></span>
            <% end %>
          </dd>
        </div>
      <% end %>
      <% if resource.data.location %>
        <div>
          <dt class="font-semibold text-gray-700">Where</dt>
          <dd class="text-gray-600"><%= resource.data.location %></dd>
        </div>
      <% end %>
    </dl>

    <% if resource.data.registration_link %>
      <div class="mt-8">
        <a href="<%= resource.data.registration_link %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          Register on Luma
          <svg class="ml-2 h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    <% end %>

    <% if resource.data.image %>
      <img src="<%= relative_url(resource.data.image) %>" alt="" class="mt-10 w-full rounded-2xl aspect-[16/9] object-cover bg-gray-100" />
    <% end %>

    <div class="prose prose-lg mt-12 max-w-none prose-headings:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <%= yield %>
    </div>
  </article>
<% end %>
