---
layout: default
---
<%
  kind = resource.data.kind&.to_s
  kind_color = case kind
               when "new" then "bg-primary-50 text-primary-700"
               when "fix" then "bg-coral-50 text-coral-700"
               when "improvement" then "bg-blue-50 text-blue-700"
               when "update" then "bg-golden-yellow-50 text-golden-yellow-800"
               else "bg-gray-100 text-gray-700"
               end
%>
<%= render Container.new(outer_class: "mt-16 sm:mt-24") do %>
  <article class="max-w-3xl">
    <nav class="flex text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-500">
        <li><a href="/" class="hover:text-primary-600">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/announcements/" class="hover:text-primary-600">Announcements</a></li>
      </ol>
    </nav>

    <div class="mt-6 flex items-center gap-3">
      <% if kind %>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide <%= kind_color %>">
          <%= kind %>
        </span>
      <% end %>
      <% if resource.data.published_at %>
        <time class="text-sm text-gray-500" datetime="<%= resource.data.published_at %>">
          <%= Date.parse(resource.data.published_at.to_s).strftime("%B %-d, %Y") %>
        </time>
      <% end %>
    </div>

    <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      <%= resource.data.title %>
    </h1>

    <div class="prose prose-lg mt-12 max-w-none prose-headings:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <%= yield %>
    </div>
  </article>
<% end %>
