---
layout: default
---
<%= render Container.new(outer_class: "mt-16 sm:mt-24") do %>
  <article class="max-w-3xl">
    <nav class="flex text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-500">
        <li><a href="/" class="hover:text-primary-600">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/articles/" class="hover:text-primary-600">Articles</a></li>
      </ol>
    </nav>

    <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      <%= resource.data.title %>
    </h1>

    <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500">
      <% if resource.data.published_at %>
        <time datetime="<%= resource.data.published_at %>">
          <%= Date.parse(resource.data.published_at.to_s).strftime("%B %-d, %Y") %>
        </time>
      <% end %>
      <% author_key = resource.data.author %>
      <% if author_key && site.data.authors && site.data.authors[author_key] %>
        <span aria-hidden="true">·</span>
        <span>By <a href="<%= relative_url("/articles/author/#{author_key}/") %>" class="font-medium text-gray-700 hover:text-primary-600"><%= site.data.authors[author_key]["name"] %></a></span>
      <% end %>
      <% if resource.data.tags&.any? %>
        <span aria-hidden="true">·</span>
        <ul class="flex flex-wrap gap-2">
          <% resource.data.tags.each do |tag| %>
            <li>
              <a href="<%= relative_url("/articles/tag/#{tag}/") %>" class="inline-flex items-center rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700 hover:bg-primary-100">
                <%= site.data.tags&.[](tag)&.[]("name") || tag %>
              </a>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <% if resource.data.image %>
      <img src="<%= relative_url(resource.data.image) %>" alt="" class="mt-10 w-full rounded-2xl aspect-[16/9] object-cover bg-gray-100" />
    <% end %>

    <div class="prose prose-lg mt-12 max-w-none prose-headings:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <%= yield %>
    </div>
  </article>
<% end %>
