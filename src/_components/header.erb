<header class="relative z-50 flex flex-none flex-col">
  <div class="top-0 z-10 h-20 pt-4">
    <%= render Container.new do %>
      <div class="flex items-center justify-between gap-6">
        <a href="/" aria-label="Rose City Robotics — Home" class="flex items-center gap-3">
          <img src="<%= relative_url('/images/mark.svg') %>" alt="" class="h-10 w-10" />
          <span class="font-bold tracking-tight text-gray-900 text-lg hidden sm:inline">Rose City Robotics</span>
        </a>

        <div class="md:hidden" data-controller="toggle">
          <button
            class="flex items-center rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-gray-800 shadow-lg ring-1 shadow-gray-800/5 ring-gray-900/5 backdrop-blur-sm"
            data-action="click->toggle#toggleMenu"
            data-toggle-target="button"
          >
            Menu
            <svg viewBox="0 0 8 6" aria-hidden="true" class="ml-3 h-auto w-2 stroke-gray-500">
              <path d="M1.75 1.75 4 4.25l2.25-2.5" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>

        <nav class="hidden md:block">
          <ul class="flex items-center gap-x-6 text-sm font-medium text-gray-800">
            <% navigation_items.each do |item| %>
              <li>
                <a href="<%= item[:href] %>"
                   class="transition hover:text-primary-600 <%= 'text-primary-600' if current?(item[:href]) %>">
                  <%= item[:name] %>
                </a>
              </li>
            <% end %>
          </ul>
        </nav>
      </div>
    <% end %>
  </div>

  <div
    class="mobile-menu fixed inset-x-4 top-8 z-50 origin-top rounded-3xl bg-white p-8 ring-1 ring-gray-900/5 transition duration-150 hidden"
    role="dialog"
    aria-modal="true"
    data-toggle-target="menu"
  >
    <div class="flex flex-row-reverse items-center justify-between">
      <button aria-label="Close menu" class="-m-1 p-1" data-action="click->toggle#toggleMenu" data-toggle-target="closeButton">
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 text-gray-500">
          <path d="m17.25 6.75-10.5 10.5M6.75 6.75l10.5 10.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <h2 class="text-sm font-medium text-gray-600">Navigation</h2>
    </div>
    <nav class="mt-6">
      <ul class="-my-2 divide-y divide-gray-100 text-base text-gray-800">
        <% navigation_items.each do |item| %>
          <li><a href="<%= item[:href] %>" class="block py-2" data-action="click->toggle#closeMenu"><%= item[:name] %></a></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
